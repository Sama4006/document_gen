<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xsi:type="TaskPaneApp">
  <Id>12345678-1234-1234-1234-123456789012</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>AI Document Generator</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="AI Document Generator"/>
  <Description DefaultValue="Generate and populate Word documents using AI and RAG"/>
  
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  
  <DefaultSettings>
    <SourceLocation DefaultValue="https://yourserver.com/taskpane.html"/>
  </DefaultSettings>
  
  <Permissions>ReadWriteDocument</Permissions>
  
  <ExtensionPoint xsi:type="PrimaryCommandSurface">
    <OfficeMenu id="OfficeAppMenu">
      <Button id="TaskPaneButton">
        <Label resid="TaskPaneButton.Label"/>
        <Supertip>
          <Title resid="TaskPaneButton.Label"/>
          <Description resid="TaskPaneButton.Tooltip"/>
        </Supertip>
        <Action xsi:type="ShowTaskPane">
          <TaskpaneId>ButtonId1</TaskpaneId>
          <SourceLocation resid="Taskpane.Url"/>
        </Action>
      </Button>
    </OfficeMenu>
  </ExtensionPoint>
  
  <Resources>
    <bt:Images>
      <bt:Image id="icon16" DefaultValue="https://yourserver.com/assets/icon-16.png"/>
      <bt:Image id="icon32" DefaultValue="https://yourserver.com/assets/icon-32.png"/>
      <bt:Image id="icon80" DefaultValue="https://yourserver.com/assets/icon-80.png"/>
    </bt:Images>
    <bt:Urls>
      <bt:Url id="Taskpane.Url" DefaultValue="https://yourserver.com/taskpane.html"/>
      <bt:Url id="Commands.Url" DefaultValue="https://yourserver.com/commands.html"/>
    </bt:Urls>
    <bt:ShortStrings>
      <bt:String id="TaskPaneButton.Label" DefaultValue="AI Generator"/>
    </bt:ShortStrings>
    <bt:LongStrings>
      <bt:String id="TaskPaneButton.Tooltip" DefaultValue="Generate and populate Word documents with AI"/>
    </bt:LongStrings>
  </Resources>
</OfficeApp>
